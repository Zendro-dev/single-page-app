# node:14.13.1-stretch-slim (Debian 9) is EOL - deb.debian.org/
# security.debian.org no longer serve it, and its baked-in archive signing
# keys have since expired, so apt can't install anything trustworthy from it
# anymore. bullseye is still in normal Debian support.
FROM node:24-bullseye-slim

# Create app directory
WORKDIR /usr/src/app

# Path to binary jq (used by node-jq)
ENV JQ_PATH=/usr/bin/jq

# Man folders are required to install postgres-client without errors
RUN mkdir -p /usr/share/man/man1 /usr/share/man/man7

# Clone the skeleton project and install dependencies
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y git procps autoconf libtool make jq postgresql-client

EXPOSE 3000

